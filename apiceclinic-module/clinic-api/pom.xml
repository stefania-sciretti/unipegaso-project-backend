<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.clinica</groupId>
        <artifactId>clinica-sanitaria</artifactId>
        <version>1.0.0</version>
        <!-- dal modulo clinic-api risali di due livelli a backend/pom.xml -->
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <groupId>com.clinic</groupId>
    <artifactId>clinic-api</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>
    <name>Clinic API DTOs</name>

    <dependencies>
        <!-- Kotlin base (ereditato dal parent) -->
        <!-- rimosse kotlin-stdlib e kotlin-reflect perché dichiarate nel parent -->

        <!-- Jackson + java.time (versione gestita da Spring Boot BOM) -->
        <dependency>
            <groupId>com.fasterxml.jackson.module</groupId>
            <artifactId>jackson-module-kotlin</artifactId>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.datatype</groupId>
            <artifactId>jackson-datatype-jsr310</artifactId>
        </dependency>

        <!-- Jackson annotations (usate dal codice generato dall'OpenAPI generator) -->
    </dependencies>

    <build>
        <sourceDirectory>${project.basedir}/src/main/kotlin</sourceDirectory>

        <plugins>
            <!-- Il plugin Kotlin è ereditato dal parent; evitiamo la duplicazione qui -->

            <!-- OpenAPI Generator: genera SOLO DTO (model) in com.clinic.model -->
            <plugin>
                <groupId>org.openapitools</groupId>
                <artifactId>openapi-generator-maven-plugin</artifactId>
                <version>${openapi.generator.version}</version>
                <executions>
                    <!-- Appointment -->
                    <execution>
                        <id>generate-appointment-models</id>
                        <phase>generate-sources</phase>
                        <goals><goal>generate</goal></goals>
                        <configuration>
                            <inputSpec>${project.basedir}/src/main/resources/openapi/Appointment.yml</inputSpec>
                            <output>${project.basedir}/generated-appointment</output>

                            <!-- SOLO model -->
                            <generatorName>kotlin</generatorName>
                            <modelPackage>com.clinic.model</modelPackage>
                            <modelOnly>true</modelOnly>

                            <!-- niente API, niente supporting files -->
                            <apiPackage>ignore.api</apiPackage>
                            <generateModelTests>false</generateModelTests>
                            <generateApiTests>false</generateApiTests>
                            <generateApiDocumentation>false</generateApiDocumentation>
                            <generateModelDocumentation>false</generateModelDocumentation>
                            <generateSupportingFiles>false</generateSupportingFiles>
                            <supportingFilesToGenerate/>

                            <configOptions>
                                <dateLibrary>java8</dateLibrary>
                                <serializationLibrary>jackson</serializationLibrary>
                                <useBeanValidation>true</useBeanValidation>
                                <useSpringBoot3>true</useSpringBoot3>
                            </configOptions>
                        </configuration>
                    </execution>

                    <!-- DietPlan -->
                    <execution>
                        <id>generate-dietplan-models</id>
                        <phase>generate-sources</phase>
                        <goals><goal>generate</goal></goals>
