                </executions>
            </plugin>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <id>add-openapi-sources</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>add-source</goal>
                        </goals>
                        <configuration>
                            <sources>
                                <source>${project.basedir}/generated-appointment/src/main/kotlin/com/clinic/model</source>
                                <source>${project.basedir}/generated-dietplan/src/main/kotlin/com/clinic/model</source>
                                <source>${project.basedir}/generated-fitness/src/main/kotlin/com/clinic/model</source>
                                <source>${project.basedir}/generated-glycemia/src/main/kotlin/com/clinic/model</source>
                                <source>${project.basedir}/generated-patient/src/main/kotlin/com/clinic/model</source>
                                <source>${project.basedir}/generated-staff/src/main/kotlin/com/clinic/model</source>
                                <source>${project.basedir}/generated-recipe/src/main/kotlin/com/clinic/model</source>
                                <source>${project.basedir}/generated-report/src/main/kotlin/com/clinic/model</source>
                                <source>${project.basedir}/generated-service/src/main/kotlin/com/clinic/model</source>
                                <source>${project.basedir}/generated-trainingplan/src/main/kotlin/com/clinic/model</source>
                            </sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>