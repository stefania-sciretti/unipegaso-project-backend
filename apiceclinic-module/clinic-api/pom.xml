                        <goals><goal>generate</goal></goals>
                        <configuration>
                            <inputSpec>${project.basedir}/src/main/resources/openapi/Recipe.yml</inputSpec>
                            <output>${project.basedir}/generated-recipe</output>

                            <generatorName>kotlin</generatorName>
                            <modelPackage>com.clinic.model</modelPackage>
