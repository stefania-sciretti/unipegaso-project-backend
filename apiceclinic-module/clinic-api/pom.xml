                    </execution>

                    <!-- TrainingPlan -->
                    <execution>
                        <id>generate-trainingplan-models</id>
                        <phase>generate-sources</phase>
                        <goals><goal>generate</goal></goals>
                        <configuration>
                            <inputSpec>${project.basedir}/src/main/resources/openapi/TrainingPlan.yml</inputSpec>
                            <output>${project.basedir}/generated-trainingplan</output>

                            <generatorName>kotlin</generatorName>
                            <modelPackage>com.clinic.model</modelPackage>
